# ==========================================
# 1. Python & Backend (FastAPI / Alembic)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.python-version
.venv/
venv/
ENV/
env/

# 数据库迁移缓存与测试覆盖率
.coverage
htmlcov/

# ==========================================
# 2. Frontend (Next.js / Node.js)
# ==========================================
# 依赖包（绝对不要提交）
frontend/node_modules/

# Next.js 编译产物
frontend/.next/
frontend/out/

# 构建输出
frontend/build/
frontend/dist/

# 日志文件
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/.pnpm-debug.log*

# ==========================================
# 3. Environment & Security (信安专业重点)
# ==========================================
# 后端环境变量
.env
.env.*

# 前端本地环境变量
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# ==========================================
# 4. Infrastructure & IDE & OS
# ==========================================
# Docker 数据卷 (MySQL 和 MinIO 的持久化数据)
data/

# PyCharm/IntelliJ IDEA 配置文件
.idea/

# 操作系统临时文件
.DS_Store
Thumbs.db