# created by virtualenv automatically

# Python 字节码与缓存
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.python-version

# 虚拟环境 (根据你的 .iml 和 README 确认使用的是 .venv)
.venv/
venv/
ENV/
env/

# 环境变量文件 (包含数据库密码等敏感信息，绝对不能提交)
.env
.env.*

# Docker 数据卷 (MySQL 和 MinIO 的持久化数据)
data/

# PyCharm/IntelliJ IDEA 配置文件
.idea/
# 如果你想保留一些项目设置，可以只忽略敏感部分
# .idea/workspace.xml
# .idea/shelf/
# .idea/dataSources/
# .idea/dataSources.local.xml

# 操作系统临时文件
.DS_Store
Thumbs.db

# 数据库迁移缓存
.coverage
htmlcov/